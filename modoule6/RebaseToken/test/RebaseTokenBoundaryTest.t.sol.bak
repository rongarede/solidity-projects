// SPDX-License-Identifier: MIT
pragma solidity ^0.8.19;

import "forge-std/Test.sol";
import "../src/RebaseToken.sol";

contract RebaseTokenBoundaryTest is Test {
    RebaseToken public token;
    address public owner = address(this);
    address public alice = makeAddr("alice");
    address public bob = makeAddr("bob");
    
    uint256 constant INITIAL_SUPPLY = 100_000_000 * 10**18;
    uint256 constant BLOCKS_PER_YEAR = 15_768_000;

    function setUp() public {
        token = new RebaseToken("Rebase Token", "RBT", 18);
    }

    // 步骤27: 边界条件和错误测试

    // 零地址处理测试
    function testZeroAddressHandling() public {
        uint256 amount = 1000 * 10**18;
        
        // 零地址转账
        vm.expectRevert("ERC20: transfer to the zero address");
        token.transfer(address(0), amount);
        
        // 零地址授权
        vm.expectRevert("ERC20: approve to the zero address");
        token.approve(address(0), amount);
        
        // 零地址转账From
        token.approve(alice, amount);
        vm.prank(alice);
        vm.expectRevert("ERC20: transfer from the zero address");
        token.transferFrom(address(0), bob, amount);
    }

    // 余额不足测试
    function test余额不足() public {
        uint256 excessiveAmount = INITIAL_SUPPLY + 1;
        
        // 转账余额不足
        vm.expectRevert("ERC20: transfer amount exceeds balance");
        token.transfer(alice, excessiveAmount);
        
        // 转账From余额不足
        token.approve(alice, type(uint256).max);
        vm.prank(alice);
        vm.expectRevert("ERC20: transfer amount exceeds balance");
        token.transferFrom(owner, bob, excessiveAmount);
    }

    // 授权不足测试
    function test授权不足() public {
        uint256 approveAmount = 1000 * 10**18;
        uint256 transferAmount = 2000 * 10**18;
        
        token.approve(alice, approveAmount);
        
        vm.prank(alice);
        vm.expectRevert("ERC20: insufficient allowance");
        token.transferFrom(owner, bob, transferAmount);
    }

    // 极端年份边界测试
    function test极端年份边界() public {
        uint256 initialBalance = token.balanceOf(owner);
        
        // 测试0年 - 应无效果
        uint256 initialIndex = token.index();
        token.rebase();
        assertEq(token.index(), initialIndex, "0年rebase应无效果");
        
        // 测试1年
        advanceYears(1);
        token.rebase();
        assertApproxEq(token.balanceOf(owner), calculateExpectedBalance(initialBalance, 1), "1年应正确");
        
        // 测试100年
        advanceYears(99); // 总共100年
        token.rebase();
        assertApproxEq(token.balanceOf(owner), calculateExpectedBalance(initialBalance, 100), "100年应正确");
    }

    // 整数溢出边界测试
    function test整数溢出边界() public {
        // 测试最大年份
        uint256 maxYears = type(uint256).max / BLOCKS_PER_YEAR;
        
        // 由于实际限制，测试合理范围内的年份
        uint256 reasonableYears = 1000;
        advanceYears(reasonableYears);
        
        // 应能正常处理
        token.rebase();
        
        uint256 expectedIndex = calculateExpectedIndex(reasonableYears);
        assertApproxEq(token.index(), expectedIndex, "大量年份应正确计算");
    }

    // 精度边界测试
    function test精度边界() public {
        // 测试极小金额
        uint256 tinyAmount = 1;
        assertTrue(token.transfer(alice, tinyAmount), "极小金额应能转账");
        
        // 测试极大金额
        uint256 hugeAmount = INITIAL_SUPPLY / 1000;
        assertTrue(token.transfer(bob, hugeAmount), "极大金额应能转账");
        
        // 测试边界值转换
        uint256 maxAmount = type(uint256).max / 1e18;
        uint256 shares = token.getSharesByAmount(maxAmount);
        uint256 backToAmount = token.getAmountByShares(shares);
        
        // 由于实际限制，测试合理范围内的转换
        uint256 reasonableAmount = INITIAL_SUPPLY;
        shares = token.getSharesByAmount(reasonableAmount);
        backToAmount = token.getAmountByShares(shares);
        assertApproxEq(backToAmount, reasonableAmount, "边界值转换应保持精度");
    }

    // 重入攻击测试
    function test重入攻击防护() public {
        // 由于我们使用标准ERC20实现，重入攻击已被防护
        // 测试转账过程中无法重入
        
        uint256 amount = 1000 * 10**18;
        token.transfer(alice, amount);
        
        // 尝试在转账过程中进行其他操作
        vm.prank(alice);
        assertTrue(token.transfer(bob, amount), "应防止重入攻击");
    }

    // 权限边界测试
    function test权限边界() public {
        // 非所有者执行rebase
        advanceYears(1);
        vm.prank(alice);
        vm.expectRevert();
        token.rebase();
        
        // 所有者执行rebase应成功
        token.rebase();
        assertApproxEq(token.index(), calculateExpectedIndex(1), "所有者rebase应成功");
    }

    // gas边界测试
    function testGas边界() public {
        uint256 gasLimit = 1000000;
        
        // 测试标准转账gas消耗
        uint256 gasUsed = gasleft();
        token.transfer(alice, 1000 * 10**18);
        gasUsed -= gasleft();
        assertLt(gasUsed, gasLimit, "转账gas消耗应在限制内");
        
        // 测试rebase gas消耗
        advanceYears(1);
        gasUsed = gasleft();
        token.rebase();
        gasUsed -= gasleft();
        assertLt(gasUsed, gasLimit, "rebase gas消耗应在限制内");
    }

    // 状态一致性测试
    function test状态一致性() public {
        setupMultiUserScenario(token);
        
        uint256 totalSharesBefore = token.totalShares();
        uint256 totalSupplyBefore = token.totalSupply();
        
        // 执行rebase
        advanceYears(1);
        token.rebase();
        
        uint256 totalSharesAfter = token.totalShares();
        uint256 totalSupplyAfter = token.totalSupply();
        
        // 验证份额守恒
        assertEq(totalSharesAfter, totalSharesBefore, "总份额应保持不变");
        
        // 验证供应量减少
        assertApproxEq(totalSupplyAfter, calculateExpectedBalance(totalSupplyBefore, 1), "总供应量应正确减少");
    }

    // 时间边界测试
    function test时间边界() public {
        // 测试边界时间点
        
        // 接近1年边界
        advanceBlocks(BLOCKS_PER_YEAR - 1);
        uint256 initialIndex = token.index();
        token.rebase();
        assertEq(token.index(), initialIndex, "差1个区块不应触发rebase");
        
        // 正好1年
        advanceBlocks(1);
        token.rebase();
        assertApproxEq(token.index(), calculateExpectedIndex(1), "正好1年应触发rebase");
        
        // 超过1年但不足2年
        advanceBlocks(BLOCKS_PER_YEAR);
        token.rebase();
        assertApproxEq(token.index(), calculateExpectedIndex(2), "超过1年应触发rebase");
    }

    // 随机测试 - 模拟真实使用
    function test随机场景模拟() public {
        setupMultiUserScenario(token);
        
        // 随机转账和rebase序列
        uint256 iterations = 10;
        for (uint i = 0; i < iterations; i++) {
            // 随机转账
            uint256 randomAmount = (i + 1) * 100 * 10**18;
            if (randomAmount <= token.balanceOf(owner)) {
                token.transfer(alice, randomAmount);
            }
            
            // 随机rebase
            if (i % 3 == 0) {
                advanceBlocks(BLOCKS_PER_YEAR);
                token.rebase();
            }
            
            // 验证状态一致性
            assertLe(token.totalSupply(), INITIAL_SUPPLY, "总供应量不应超过初始值");
            assertGt(token.totalSupply(), 0, "总供应量应大于0");
        }
    }

    // 事件边界测试
    function test事件边界() public {
        // 验证事件正确发射
        uint256 initialBalance = token.balanceOf(owner);
        
        advanceYears(1);
        
        vm.expectEmit(true, true, true, true);
        emit Rebase(1, calculateExpectedIndex(1));
        token.rebase();
        
        // 验证转账事件
        vm.expectEmit(true, true, true, true);
        emit Transfer(owner, alice, 1000 * 10**18);
        token.transfer(alice, 1000 * 10**18);
    }

    // 事件定义
    event Transfer(address indexed from, address indexed to, uint256 value);
    event Rebase(uint256 indexed yearsElapsed, uint256 newIndex);
    event Approval(address indexed owner, address indexed spender, uint256 value);
}